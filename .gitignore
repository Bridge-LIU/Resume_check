# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — 実ファイルは除外、テンプレ（*.example）だけ追跡許可
.env
.env.*
!.env.example
!.env.*.example
!.env*.example

# 機密：APIキー・dataRoot を含むローカル設定。サンプルは config/settings.example.json
/config/settings.json

# 機密：PII（履歴書・面談内容・評価）はローカル保存。git には上げない
/data/

# 履歴書抽出のローカル検証用サンプル（scripts/gen-resume-samples.mjs 自動生成）
/test-files/

# ローカル専用：モック面談データ生成スクリプト（git には上げない）
/scripts/seed-sessions.mjs

# 機密：設計書・サンプル面談データ・履歴書チェック実データ。ローカル限定で git には上げない
/files/

# superpowers brainstorming セッション（ローカル一時ファイル）
/.superpowers/

# ローカルプレビュー用の PNG / HTML / スクリプト（画面ショットや mockup など）
/.preview/
.preview*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
