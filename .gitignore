# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — 実ファイルは除外、テンプレ（*.example）だけ追跡許可
.env
.env.*
!.env.example
!.env.*.example
!.env*.example

# 機密：PII（履歴書・面談内容・評価）＋ APIキー含む設定。ローカル保存、git には上げない
/data/

# 履歴書抽出のローカル検証用サンプル（scripts/dev/gen-resume-samples.mjs 自動生成）
/test-files/

# 開発者専用スクリプト（seed / claude-Nsplit / mockup 資材生成など、配布に含めない）
/scripts/dev/

# superpowers brainstorming セッション（ローカル一時ファイル）
/.superpowers/

# ローカルプレビュー用の PNG / HTML / スクリプト（画面ショットや mockup など）
/.preview/
.preview*

# auto-shutdown で lib/heartbeat.ts が書き出す終了理由（start.bat が読取・削除）
# 診断モードではタイムスタンプ付きでリネームして残す (`.auto-shutdown.reason.YYYYMMDD_HHMMSS`)
.auto-shutdown.reason
.auto-shutdown.reason.*

# 診断モード：app/api/heartbeat/route.ts が POST/GET 到達を追記する
# module state と独立に到達数を計測して pingLog 0 の原因を切り分ける
.heartbeat-arrivals.log
.heartbeat-arrivals.log.*

# 配布 ZIP 実験置き場（pkg-v*, app-v*.zip 等の展開済みビルド成果物、数百 MB）
/test-release/

# start.bat portable Node.js（初回起動時に自動展開）
/node-portable/
/node-portable.zip

# 開発中の preview mockup（配布対象外、コミット前提としない）
/app/preview-*/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
