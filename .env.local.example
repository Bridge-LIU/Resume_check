# このファイルをコピーして「.env.local」を作成してください。
# 中身：Anthropic の API キーを下に貼り付けて保存するだけ。
#
# .env.local は .gitignore で除外されているため git には上がりません。
# /settings UI から保存する方法でも OK（その場合は本ファイル不要）。

ANTHROPIC_API_KEY=

# 開発者専用：/settings に「配布用 ZIP 出力」ボタンを表示し、
# /api/settings/export-clean エンドポイントを有効化する。
# 配布された環境では設定しないこと（未設定＝ボタン非表示＋エンドポイント 404）。
# ENABLE_DEV_EXPORT=1

